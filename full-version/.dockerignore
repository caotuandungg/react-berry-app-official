# Dependencies (reinstalled in container)
node_modules

# Build output (rebuilt in container)
build
dist

# Environment files (secrets — NEVER include in image)
.env
.env.*
!.env.example

# Version control
.git
.gitignore

# IDE & editor
.vscode
.idea
*.swp
*.swo
*~

# Documentation (not needed in runtime)
*.md
LICENSE
docs/

# Docker files (prevent recursive context)
Dockerfile
docker-compose*.yml
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.circleci

# Testing
coverage
__tests__
*.test.*
*.spec.*

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Config files not needed in build
.eslintrc
.prettierrc
.editorconfig
